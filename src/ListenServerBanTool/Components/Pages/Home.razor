@page "/"
@using Data.Bans
@using Data.Model
@using Data.PlayerTracker
@implements IDisposable
@rendermode InteractiveServer

<PageTitle>Player Dashboard</PageTitle>

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Player Name</th>
                        <th class="text-center">Immunity</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!_activePlayers?.Any() ?? true)
                    {
                        <tr>
                            <td colspan="3" class="text-center py-4 text-muted">No players currently online.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var player in _activePlayers!)
                        {
                            <tr>
                                <td>
                                    <strong>@player.Name (@player.SteamId)</strong>
                                </td>
                                <td class="text-center">
                                    <span class="badge rounded-pill @(player.IsImmune ? "bg-success" : "bg-danger")">
                                        @(player.IsImmune ? "Immune" : "Bannable")
                                    </span>
                                </td>
                                <td class="text-end">
                                    <button class="btn btn-outline-danger btn-sm"
                                            @onclick="() => SetPlayerImmunityAsync(player, !player.IsImmune)"
                                            title="Toggle Immunity">
                                        <i class="bi bi-shield-lock"></i> Toggle Immunity
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm"
                                            disabled="@player.IsImmune"
                                            @onclick="() => ConfirmBanAsync(player)"
                                            title="Ban Player">
                                        <i class="bi bi-hammer"></i> Ban
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {

    [Inject]
    public required IBanManager BanManager { get; set; }

    [Inject]
    public required IPlayerTracker PlayerTracker { get; set; }

    [Inject]
    public required ILogger<Home> Logger { get; set; }

    private IEnumerable<ActivePlayer>? _activePlayers;

    protected override void OnInitialized()
    {
        PlayerTracker.OnTrackedPlayersUpdate += UpdateAsync;
        _activePlayers = PlayerTracker.GetAllActivePlayers();
    }

    private async Task ConfirmBanAsync(ActivePlayer player)
    {
        await BanManager.AddBanAsync(player.SteamId, player.Name ?? "unnamed");

        Logger.LogInformation("{Player} has been banned from the dashboard.", player.Name ?? "unnamed");
    }

    private async Task SetPlayerImmunityAsync(ActivePlayer player, bool isImmune)
    {
        await PlayerTracker.SetPlayerImmunityAsync(player.SteamId, isImmune);
        Logger.LogInformation("{Player} immunity set to {Immunity}.", player.Name ?? "unnamed", isImmune);
    }

    private async void UpdateAsync()
    {
        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        PlayerTracker.OnTrackedPlayersUpdate -= UpdateAsync;
    }
}